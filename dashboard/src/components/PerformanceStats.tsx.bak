    { rank: '02', name: '运维二所', score: 96, color: 'from-orange-500 to-yellow-500' },
    { rank: '03', name: '运维三所', score: 93, color: 'from-green-500 to-emerald-500' },
    { rank: '04', name: '综合服务所', score: 89, color: 'from-blue-500 to-indigo-500' }
  ];

  return (
    <div className="chart-panel p-5">
      <h3 className="text-xl font-bold text-blue-600 mb-5 tracking-wide">绩效统计</h3>
      <div className="space-y-4">
        {performanceData.map((item, index) => (
          <div key={index} className="flex items-center gap-4 group">
            <div className={g-gradient-to-r  text-white px-4 py-2 rounded-full text-sm font-bold w-24 text-center shadow-md group-hover:scale-105 transition-transform}>
              {item.rank}
